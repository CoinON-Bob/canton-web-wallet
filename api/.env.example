# Canton Wallet API - Environment variables
# Copy to .env and fill in values.

NODE_ENV=development
PORT=3000

# PostgreSQL (required)
DATABASE_URL=postgresql://user:password@localhost:5432/canton_wallet

# Redis (optional, for cache/sessions later)
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT (required, min 16 chars)
JWT_SECRET=your-super-secret-jwt-key-min-16-chars
JWT_EXPIRES_IN=7d
