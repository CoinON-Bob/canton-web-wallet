# Canton Wallet API - Environment variables
# Copy to .env and fill in values. Do not commit .env or real secrets.

NODE_ENV=development
PORT=3000

# PostgreSQL (required) - e.g. Supabase or local Postgres
DATABASE_URL=postgresql://user:password@host:5432/postgres

# JWT (required, min 16 characters)
JWT_SECRET=your-super-secret-jwt-key-min-16-chars
JWT_EXPIRES_IN=7d

# Redis (optional, for cache/sessions later)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Or use single URL: REDIS_URL=redis://localhost:6379
