// Canton Wallet API - Prisma Schema
// Security: No plaintext private keys. Key material stored only in encrypted form.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  emailVerified Boolean  @default(false) @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessions            UserSession[]
  wallets             Wallet[]
  addressBook         AddressBookEntry[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  emailVerifications  EmailVerification[]

  @@map("users")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("user_sessions")
}

model EmailVerification {
  id        String    @id @default(uuid())
  userId    String?   @map("user_id")
  email     String
  codeHash  String    @map("code_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([userId])
  @@map("email_verifications")
}

model Wallet {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  label          String?  // user-facing label
  nodeAccountId  String?  @unique @map("node_account_id") // Node API account id (party id)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  keystores WalletKeystore[]

  @@index([userId])
  @@map("wallets")
}

// Encrypted key material only. Backend never handles plaintext private keys.
model WalletKeystore {
  id          String   @id @default(uuid())
  walletId    String   @map("wallet_id")
  keyId       String   @map("key_id")   // e.g. canton key identifier
  encryptedPayload String @map("encrypted_payload") // ciphertext only
  keyVersion  Int      @default(1) @map("key_version")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, keyId])
  @@index([walletId])
  @@map("wallet_keystores")
}

model AddressBookEntry {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  label       String
  address     String   // Canton address (public)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("address_book")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  body      String?  @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  resource   String?
  details    String?  @db.Text
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id    String @id
  value String @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
